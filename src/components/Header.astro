---
interface Props {
    activeNav?: string;
}

const { activeNav } = Astro.props;

const navItems = [
    { linkText: 'About', href: '/' },
    { linkText: 'Resume', href: '/resume' },
    { linkText: 'Experience & Skills', href: '/experience' },
    { linkText: 'Interests', href: '/interests' },
    { linkText: 'Photography', href: '/photography' }
];
---

<nav class="flex flex-wrap items-center gap-4 pt-6 pb-12 sm:pt-10 sm:pb-16">
    <a href="/" class="text-xl font-bold text-white no-underline tracking-tight hover:text-primary-light transition-colors mr-4">
        <!-- Replace with your name -->
        Your Name
    </a>
    {
        !!navItems?.length && (
            <ul class="flex flex-wrap gap-1">
                {navItems.map((item) => (
                    <li>
                        <a
                            href={item.href}
                            class:list={[
                                'nav-link',
                                { 'nav-link-active': activeNav === item.href }
                            ]}
                        >
                            {item.linkText}
                        </a>
                    </li>
                ))}
            </ul>
        )
    }
</nav>
