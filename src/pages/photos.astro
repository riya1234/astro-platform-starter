---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Your Name — Experience & Skills" activeNav="/experience">
    <h1 class="mb-4">Experience & Skills</h1>
    <p class="text-gray-400 mb-10 max-w-2xl">
        A deeper look at my professional experience, academic achievements, and the skills
        I've developed through coursework and hands-on work.
    </p>

    <!-- Professional Experience -->
    <section class="mb-14">
        <h2 class="section-heading">Professional Experience</h2>
        <div class="space-y-6">
            <!-- Experience Item 1 - Detailed -->
            <div class="card">
                <div class="flex flex-col sm:flex-row sm:justify-between gap-1 mb-1">
                    <h3>Job Title / Role</h3>
                    <span class="text-sm text-muted">Month Year — Present</span>
                </div>
                <p class="text-primary-light font-medium mb-3">Company / Organization — Los Angeles, CA</p>
                <p class="text-sm text-gray-300 mb-3">
                    <!-- Write a brief paragraph about the role and your overall contribution -->
                    Provide a 2-3 sentence overview of the role, the team you worked with,
                    and the kind of problems you solved.
                </p>
                <ul class="list-disc list-inside text-sm text-gray-400 space-y-2">
                    <li>Key achievement or responsibility with measurable impact</li>
                    <li>Another significant contribution to the team or project</li>
                    <li>Skills or tools you used and what you learned</li>
                </ul>
                <div class="flex flex-wrap gap-2 mt-4">
                    <span class="tag">Python</span>
                    <span class="tag">Data Analysis</span>
                    <span class="tag">Excel</span>
                </div>
            </div>

            <!-- Experience Item 2 - Detailed -->
            <div class="card">
                <div class="flex flex-col sm:flex-row sm:justify-between gap-1 mb-1">
                    <h3>Job Title / Role</h3>
                    <span class="text-sm text-muted">Month Year — Month Year</span>
                </div>
                <p class="text-primary-light font-medium mb-3">Company / Organization — City, State</p>
                <p class="text-sm text-gray-300 mb-3">
                    Provide a 2-3 sentence overview of the role.
                </p>
                <ul class="list-disc list-inside text-sm text-gray-400 space-y-2">
                    <li>Key achievement or responsibility</li>
                    <li>Another significant contribution</li>
                </ul>
                <div class="flex flex-wrap gap-2 mt-4">
                    <span class="tag">R</span>
                    <span class="tag">Statistical Analysis</span>
                </div>
            </div>
        </div>
    </section>

    <!-- Technical Skills Deep Dive -->
    <section class="mb-14">
        <h2 class="section-heading">Technical Skills</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="card">
                <h3 class="text-lg mb-3">Programming & Data</h3>
                <div class="space-y-3">
                    <div>
                        <div class="flex justify-between text-sm mb-1">
                            <span class="text-gray-300">Python</span>
                            <span class="text-muted">Advanced</span>
                        </div>
                        <div class="w-full bg-surface-lighter rounded-full h-2">
                            <div class="bg-primary h-2 rounded-full" style="width: 85%"></div>
                        </div>
                    </div>
                    <div>
                        <div class="flex justify-between text-sm mb-1">
                            <span class="text-gray-300">R / RStudio</span>
                            <span class="text-muted">Advanced</span>
                        </div>
                        <div class="w-full bg-surface-lighter rounded-full h-2">
                            <div class="bg-primary h-2 rounded-full" style="width: 80%"></div>
                        </div>
                    </div>
                    <div>
                        <div class="flex justify-between text-sm mb-1">
                            <span class="text-gray-300">SQL</span>
                            <span class="text-muted">Intermediate</span>
                        </div>
                        <div class="w-full bg-surface-lighter rounded-full h-2">
                            <div class="bg-primary h-2 rounded-full" style="width: 70%"></div>
                        </div>
                    </div>
                    <div>
                        <div class="flex justify-between text-sm mb-1">
                            <span class="text-gray-300">Stata</span>
                            <span class="text-muted">Intermediate</span>
                        </div>
                        <div class="w-full bg-surface-lighter rounded-full h-2">
                            <div class="bg-primary h-2 rounded-full" style="width: 65%"></div>
                        </div>
                    </div>
                    <div>
                        <div class="flex justify-between text-sm mb-1">
                            <span class="text-gray-300">Excel / Google Sheets</span>
                            <span class="text-muted">Advanced</span>
                        </div>
                        <div class="w-full bg-surface-lighter rounded-full h-2">
                            <div class="bg-primary h-2 rounded-full" style="width: 90%"></div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="card">
                <h3 class="text-lg mb-3">Analysis & Visualization</h3>
                <div class="space-y-3">
                    <div>
                        <div class="flex justify-between text-sm mb-1">
                            <span class="text-gray-300">Tableau</span>
                            <span class="text-muted">Intermediate</span>
                        </div>
                        <div class="w-full bg-surface-lighter rounded-full h-2">
                            <div class="bg-accent h-2 rounded-full" style="width: 70%"></div>
                        </div>
                    </div>
                    <div>
                        <div class="flex justify-between text-sm mb-1">
                            <span class="text-gray-300">Econometrics</span>
                            <span class="text-muted">Advanced</span>
                        </div>
                        <div class="w-full bg-surface-lighter rounded-full h-2">
                            <div class="bg-accent h-2 rounded-full" style="width: 85%"></div>
                        </div>
                    </div>
                    <div>
                        <div class="flex justify-between text-sm mb-1">
                            <span class="text-gray-300">Statistical Modeling</span>
                            <span class="text-muted">Advanced</span>
                        </div>
                        <div class="w-full bg-surface-lighter rounded-full h-2">
                            <div class="bg-accent h-2 rounded-full" style="width: 80%"></div>
                        </div>
                    </div>
                    <div>
                        <div class="flex justify-between text-sm mb-1">
                            <span class="text-gray-300">Data Visualization</span>
                            <span class="text-muted">Advanced</span>
                        </div>
                        <div class="w-full bg-surface-lighter rounded-full h-2">
                            <div class="bg-accent h-2 rounded-full" style="width: 80%"></div>
                        </div>
                    </div>
                    <div>
                        <div class="flex justify-between text-sm mb-1">
                            <span class="text-gray-300">Financial Modeling</span>
                            <span class="text-muted">Intermediate</span>
                        </div>
                        <div class="w-full bg-surface-lighter rounded-full h-2">
                            <div class="bg-accent h-2 rounded-full" style="width: 65%"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Academic Achievements -->
    <section class="mb-14">
        <h2 class="section-heading">Academic Achievements</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <!-- Replace these with your actual achievements -->
            <div class="card">
                <div class="flex items-start gap-3">
                    <div class="w-10 h-10 rounded-lg bg-primary/20 flex items-center justify-center text-primary-light flex-shrink-0 mt-0.5">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
                        </svg>
                    </div>
                    <div>
                        <h3 class="text-base">Dean's List</h3>
                        <p class="text-sm text-gray-400 mt-1">Recognized for academic excellence — update with specific quarters/years.</p>
                    </div>
                </div>
            </div>
            <div class="card">
                <div class="flex items-start gap-3">
                    <div class="w-10 h-10 rounded-lg bg-primary/20 flex items-center justify-center text-primary-light flex-shrink-0 mt-0.5">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                        </svg>
                    </div>
                    <div>
                        <h3 class="text-base">Research Assistant</h3>
                        <p class="text-sm text-gray-400 mt-1">Assisted with economic research — update with details if applicable.</p>
                    </div>
                </div>
            </div>
            <div class="card">
                <div class="flex items-start gap-3">
                    <div class="w-10 h-10 rounded-lg bg-primary/20 flex items-center justify-center text-primary-light flex-shrink-0 mt-0.5">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                        </svg>
                    </div>
                    <div>
                        <h3 class="text-base">Club / Organization</h3>
                        <p class="text-sm text-gray-400 mt-1">Update with your student organizations and leadership roles.</p>
                    </div>
                </div>
            </div>
            <div class="card">
                <div class="flex items-start gap-3">
                    <div class="w-10 h-10 rounded-lg bg-primary/20 flex items-center justify-center text-primary-light flex-shrink-0 mt-0.5">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
                        </svg>
                    </div>
                    <div>
                        <h3 class="text-base">Scholarship / Award</h3>
                        <p class="text-sm text-gray-400 mt-1">Update with any scholarships or awards you've received.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>
</Layout>
