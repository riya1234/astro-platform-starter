---
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Riya Hariyaplar | Photography</title>
    <meta name="robots" content="noindex, nofollow" />

    <style>
      :root {
        --text: #122033;
        --muted: #6b7c93;
        --accent: #2f6fed;
        --green: #6c9f5f;
      }

      body {
        margin: 0;
        font-family: Inter, system-ui, sans-serif;
        background: linear-gradient(180deg, #ffffff 0%, #f3f9f4 100%);
        color: var(--text);
      }

      .container {
        width: min(1100px, 92%);
        margin: auto;
      }

      nav {
        background: white;
        padding: 1rem 0;
        border-bottom: 1px solid #e5eaf3;
      }

      .nav-inner {
        display: flex;
        justify-content: space-between;
        align-items: center;
      }

      .nav-links a {
        margin-left: 1rem;
        text-decoration: none;
        color: var(--muted);
        font-weight: 600;
      }

      .nav-links .active {
        color: var(--green);
      }

      h1 {
        text-align: center;
        font-size: 3.2rem;
        margin-top: 2.5rem;
        margin-bottom: 0.5rem;
      }

      .subtitle {
        text-align: center;
        color: var(--muted);
        margin-bottom: 2.5rem;
      }

      .gallery {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: 1.2rem;
      }

      .gallery img {
        width: 100%;
        height: 280px;
        object-fit: cover;
        border-radius: 18px;
        transition: 0.3s ease;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
      }

      .gallery img:hover {
        transform: scale(1.03);
      }

      footer {
        text-align: center;
        margin-top: 3rem;
        color: var(--muted);
      }
    </style>
  </head>

  <body>
    <nav>
      <div class="container nav-inner">
        <div><strong>Riya Hariyaplar</strong></div>
        <div class="nav-links">
          <a href="/">About</a>
          <a href="/resume">Resume</a>
          <a href="/skills">Skills</a>
          <a href="/interests">Interests</a>
          <a href="/photos" class="active">Photos</a>
        </div>
      </div>
    </nav>

    <main class="container">
      <h1>Photography</h1>
      <p class="subtitle">
        moments, textures, and little details I wanted to keep forever 🌿
      </p>

      <div class="gallery">
        <img src="/photos/pic1.jpg" />
        <img src="/photos/pic2.jpg" />
        <img src="/photos/pic3.jpg" />
        <img src="/photos/pic4.jpg" />
        <img src="/photos/pic5.jpg" />
        <img src="/photos/pic6.jpg" />
        <img src="/photos/pic7.jpg" />
        <img src="/photos/pic8.jpg" />
      </div>
    </main>

    <footer>
      2026 Riya Hariyaplar
    </footer>
  </body>
</html>
