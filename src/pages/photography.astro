---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Your Name — Photography" activeNav="/photography">
    <h1 class="mb-4">Photography</h1>
    <p class="text-gray-400 mb-10 max-w-2xl">
        A selection of my photography work. I enjoy capturing moments that tell a story —
        from street scenes and landscapes to everyday life.
        <!-- Update this intro with your own voice -->
    </p>

    <!-- Photo Gallery -->
    <div class="columns-1 sm:columns-2 lg:columns-3 gap-4 mb-14">
        <!--
            HOW TO ADD YOUR PHOTOS:
            1. Add your photo files to the /public/images/photography/ folder
            2. Replace the placeholder blocks below with <img> tags
            3. Example: <img src="/images/photography/your-photo.jpg" alt="Description" class="w-full rounded-lg mb-4" />
        -->

        <!-- Placeholder 1 -->
        <div class="bg-surface-light border border-surface-lighter rounded-lg mb-4 aspect-[4/3] flex items-center justify-center">
            <div class="text-center p-6">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 mx-auto text-surface-lighter mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
