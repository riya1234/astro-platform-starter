    <!-- Photography Info -->
    <section class="mb-14">
        <h2 class="section-heading">About My Photography</h2>
        <div class="card">
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
                <div>
                    <h3 class="text-sm font-semibold text-gray-300 mb-2">Camera / Gear</h3>
                    <p class="text-sm text-gray-400">
                        <!-- Update with your actual camera gear -->
                        Update with your camera, lenses, or phone you shoot with.
                    </p>
                </div>
                <div>
                    <h3 class="text-sm font-semibold text-gray-300 mb-2">Favorite Subjects</h3>
                    <p class="text-sm text-gray-400">
                        <!-- Update with what you like to photograph -->
                        Street, landscape, portraits, architecture, etc.
                    </p>
                </div>
                <div>
                    <h3 class="text-sm font-semibold text-gray-300 mb-2">Editing</h3>
                    <p class="text-sm text-gray-400">
                        <!-- Update with your editing tools/style -->
                        Lightroom, VSCO, or whatever tools you use.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- Instructions for adding photos (hidden in production, visible in code) -->
    <!--
    TO ADD YOUR PHOTOS:
    1. Create the folder: /public/images/photography/
    2. Add your image files (JPG, PNG, WebP) to that folder
    3. Replace each placeholder <div> above with an <img> tag like:
       <img src="/images/photography/photo-name.jpg" alt="Description of the photo" class="w-full rounded-lg mb-4" loading="lazy" />
    4. Vary the aspect ratios for a more dynamic masonry layout
    5. Add loading="lazy" to images below the fold for better performance
    -->
</Layout>
