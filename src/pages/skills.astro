---
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Riya Hariyaplar | Skills & Achievements</title>
    <meta name="robots" content="noindex, nofollow" />

    <style>
      :root {
        --bg: #f8fbff;
        --bg-soft: #eef5ff;
        --card: rgba(255, 255, 255, 0.92);
        --card-border: rgba(96, 165, 250, 0.18);
        --text: #122033;
        --muted: #4f6480;
        --accent: #2f6fed;
        --accent-2: #5c8df6;
        --line: rgba(96, 165, 250, 0.2);
        --shadow: 0 14px 40px rgba(37, 99, 235, 0.08);
      }

      body {
        margin: 0;
        font-family: Inter, system-ui, sans-serif;
        background: linear-gradient(180deg, #ffffff 0%, #eef5ff 100%);
        color: var(--text);
      }

      .container {
        width: min(1100px, 92%);
        margin: auto;
      }

      nav {
        background: white;
        border-bottom: 1px solid #e5eaf3;
        padding: 1rem 0;
      }

      .nav-inner {
        display: flex;
        justify-content: space-between;
        align-items: center;
      }

      .brand {
        font-weight: 700;
        font-size: 1.5rem;
      }

      .nav-links a {
        margin-left: 1rem;
        text-decoration: none;
        color: var(--muted);
        font-weight: 600;
      }

      .nav-links .active {
        color: var(--accent);
      }

      main {
        padding: 3rem 0;
      }

      h1 {
        text-align: center;
        font-size: 3.5rem;
        margin-bottom: 0.5rem;
      }

      .subtitle {
        text-align: center;
        color: var(--muted);
        max-width: 700px;
        margin: auto;
      }

      section {
        margin-top: 3rem;
      }

      .section-title {
        font-size: 1.8rem;
        margin-bottom: 1rem;
      }

      .grid {
        display: grid;
        gap: 1rem;
      }

      .stats {
        grid-template-columns: repeat(4, 1fr);
      }

      .card {
        background: white;
        border-radius: 16px;
        padding: 1.5rem;
        border: 1px solid #e5eaf3;
      }

      .stat-value {
        font-size: 2.5rem;
        color: var(--accent);
        font-weight: bold;
      }

      .soft {
        grid-template-columns: repeat(3, 1fr);
      }

      .testimonials {
        grid-template-columns: repeat(2, 1fr);
      }

      .skills-bars {
        display: grid;
        gap: 1rem;
      }

      .bar {
        height: 10px;
        background: #e5eaf3;
        border-radius: 999px;
      }

      .fill {
        height: 100%;
        background: var(--accent);
        border-radius: 999px;
      }

      .certs,
      .achievements {
        grid-template-columns: repeat(2, 1fr);
      }

      footer {
        text-align: center;
        margin-top: 3rem;
        color: var(--muted);
      }
    </style>
  </head>

  <body>
    <nav>
      <div class="container nav-inner">
        <div class="brand">Riya Hariyaplar</div>
        <div class="nav-links">
          <a href="/">About</a>
          <a href="/resume">Resume</a>
          <a href="/skills" class="active">Skills</a>
          <a href="/interests">Interests</a>
        </div>
      </div>
    </nav>

    <main class="container">
      <h1>Skills & Achievements</h1>
      <p class="subtitle">
        A snapshot of my strengths, experience, and recognitions across data, product, and leadership.
      </p>

      <!-- STATS -->
      <section>
        <div class="grid stats">
          <div class="card">
            <div class="stat-value">4+</div>
            <p>Years of experience</p>
          </div>
          <div class="card">
            <div class="stat-value">20+</div>
            <p>Projects and initiatives</p>
          </div>
          <div class="card">
            <div class="stat-value">30+</div>
            <p>Teams collaborated with</p>
          </div>
          <div class="card">
            <div class="stat-value">6+</div>
            <p>Awards and recognitions</p>
          </div>
        </div>
      </section>

      <!-- SOFT SKILLS -->
      <section>
        <h2 class="section-title">Soft Skills</h2>
        <div class="grid soft">
          <div class="card">
            <h3>Communication</h3>
            <p>Strong ability to translate complex ideas clearly across teams.</p>
          </div>
          <div class="card">
            <h3>Leadership</h3>
            <p>Takes initiative and drives projects forward with structure and clarity.</p>
          </div>
          <div class="card">
            <h3>Problem Solving</h3>
            <p>Approaches problems analytically and strategically.</p>
          </div>
        </div>
      </section>

      <!-- TESTIMONIALS -->
      <section>
        <h2 class="section-title">Testimonials</h2>
        <div class="grid testimonials">
          <div class="card">
            <p>
              Riya consistently demonstrated initiative, strong ownership, and thoughtful problem solving across teams.
            </p>
            <strong>Anuradha Siva, American Express</strong>
          </div>
          <div class="card">
            <p>
              Riya brings energy, work ethic, and a collaborative mindset that elevates everyone around her.
            </p>
            <strong>Brandon Mun, Mentor</strong>
          </div>
        </div>
      </section>

      <!-- TECH SKILLS -->
      <section>
        <h2 class="section-title">Technical Skills</h2>
        <div class="skills-bars">
          <div>
            <p>SQL</p>
            <div class="bar"><div class="fill" style="width: 90%"></div></div>
          </div>
          <div>
            <p>Python</p>
            <div class="bar"><div class="fill" style="width: 85%"></div></div>
          </div>
          <div>
            <p>Product Strategy</p>
            <div class="bar"><div class="fill" style="width: 88%"></div></div>
          </div>
          <div>
            <p>Data Visualization</p>
            <div class="bar"><div class="fill" style="width: 80%"></div></div>
          </div>
          <div>
            <p>A/B Testing</p>
            <div class="bar"><div class="fill" style="width: 75%"></div></div>
          </div>
        </div>
      </section>

      <!-- CERTIFICATIONS -->
      <section>
        <h2 class="section-title">Certifications</h2>
        <div class="grid certs">
          <div class="card">
            <h3>Excel Certification</h3>
            <p>Coursera</p>
          </div>
          <div class="card">
            <h3>High Dimensional Data Analysis</h3>
            <p>Harvard edX</p>
          </div>
        </div>
      </section>

      <!-- ACHIEVEMENTS -->
      <section>
        <h2 class="section-title">Achievements</h2>
        <div class="grid achievements">
          <div class="card">
            <h3>Goldman Sachs Possibilities Summit Fellow</h3>
            <p>Highly selective program focused on finance and leadership.</p>
          </div>

          <div class="card">
            <h3>Bruin Hedge Fund</h3>
            <p>Selected with a 4 percent acceptance rate.</p>
            <a href="https://www.bruinhedgefund.com/" target="_blank">Visit site</a>
          </div>

          <div class="card" style="grid-column: span 2;">
            <h3>Speech and Debate Achievements</h3>
            <ul>
              <li>MLK Tournament, Finalist</li>
              <li>SCU Cronin Dempsey Tournament, 2nd Place</li>
              <li>Stanford Tournament, 7th Place</li>
              <li>UC Berkeley Tournament, Finalist</li>
            </ul>
          </div>
        </div>
      </section>
    </main>

    <footer>
      2026 Riya Hariyaplar
    </footer>
  </body>
</html>
