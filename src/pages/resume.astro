<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Riya Hariyaplar | Resume</title>
    <meta name="robots" content="noindex, nofollow" />

    <style>
      :root {
        --bg: #f8fbff;
        --bg-soft: #eef5ff;
        --card: rgba(255, 255, 255, 0.92);
        --card-border: rgba(96, 165, 250, 0.18);
        --text: #122033;
        --muted: #4f6480;
        --accent: #2f6fed;
        --accent-2: #5c8df6;
        --line: rgba(96, 165, 250, 0.2);
        --shadow: 0 14px 40px rgba(37, 99, 235, 0.08);
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background:
          radial-gradient(circle at top left, rgba(147, 197, 253, 0.3), transparent 30%),
          radial-gradient(circle at top right, rgba(191, 219, 254, 0.45), transparent 28%),
          linear-gradient(180deg, #ffffff 0%, #f8fbff 45%, #eef5ff 100%);
        color: var(--text);
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      .container {
        width: min(1120px, calc(100% - 2rem));
        margin: 0 auto;
      }

      nav {
        position: sticky;
        top: 0;
        z-index: 20;
        backdrop-filter: blur(14px);
        background: rgba(255, 255, 255, 0.8);
        border-bottom: 1px solid rgba(96, 165, 250, 0.12);
      }

      .nav-inner {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1.1rem 0;
        gap: 1rem;
        flex-wrap: wrap;
      }

      .brand {
        font-size: 1.8rem;
        font-weight: 700;
        letter-spacing: -0.03em;
        color: #17325c;
      }

      .nav-links {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
      }

      .nav-links a {
        color: var(--muted);
        padding: 0.7rem 1rem;
        border-radius: 999px;
        transition: 0.2s ease;
        font-weight: 600;
      }

      .nav-links a:hover {
        background: rgba(96, 165, 250, 0.12);
        color: var(--accent);
      }

      .nav-links a.active {
        background: rgba(96, 165, 250, 0.14);
        color: var(--accent);
      }

      main {
        padding: 3.5rem 0 4rem;
      }

      .page-header {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 1.25rem;
        margin-bottom: 2.75rem;
      }

      h1 {
        font-size: clamp(2.6rem, 6vw, 4.4rem);
        line-height: 1.02;
        margin: 0;
        letter-spacing: -0.05em;
        color: #10213a;
      }

      .page-subtitle {
        color: var(--muted);
        font-size: 1.08rem;
        margin-top: 0.15rem;
      }

      .contact-label-block {
        font-size: 0.95rem;
        font-weight: 700;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--accent);
        margin-top: 0.2rem;
      }

      .top-contact {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem 1.5rem;
        color: var(--muted);
        font-size: 1rem;
        align-items: center;
      }

      .contact-item {
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
      }

      .contact-item svg {
        flex-shrink: 0;
        color: var(--accent);
      }

      .contact-item a {
        color: var(--accent);
        text-decoration: underline;
      }

      .disclaimer {
        max-width: 900px;
        background: rgba(255, 255, 255, 0.78);
        border: 1px solid rgba(96, 165, 250, 0.14);
        border-radius: 20px;
        padding: 1rem 1.15rem;
        color: var(--muted);
        line-height: 1.8;
        box-shadow: 0 10px 26px rgba(37, 99, 235, 0.05);
      }

      .download-wrap {
        width: 100%;
        display: flex;
        justify-content: center;
        margin-top: 0.35rem;
      }

      .btn {
        display: inline-flex;
        align-items: center;
        gap: 0.65rem;
        border-radius: 999px;
        padding: 1rem 1.6rem;
        font-weight: 700;
        transition: 0.2s ease;
      }

      .btn-primary {
        background: linear-gradient(135deg, #2f6fed, #60a5fa);
        color: white;
        box-shadow: 0 12px 30px rgba(59, 130, 246, 0.2);
      }

      .btn-primary:hover {
        transform: translateY(-1px);
      }

      section {
        margin-top: 3.5rem;
      }

      .section-title {
        font-size: 2rem;
        margin-bottom: 0.75rem;
        color: #17325c;
      }

      .section-line {
        height: 1px;
        width: 100%;
        background: var(--line);
        margin-bottom: 1.5rem;
      }

      .card {
        background: var(--card);
        border: 1px solid var(--card-border);
        border-radius: 24px;
        box-shadow: var(--shadow);
        padding: 1.8rem;
      }

      .stack {
        display: grid;
        gap: 1rem;
      }

      .resume-item {
        background: rgba(255, 255, 255, 0.9);
        border: 1px solid rgba(96, 165, 250, 0.14);
        border-radius: 22px;
        box-shadow: 0 10px 28px rgba(37, 99, 235, 0.06);
        padding: 1.5rem;
      }

      .item-top {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 1rem;
        flex-wrap: wrap;
      }

      .item-title {
        font-size: 1.45rem;
        font-weight: 700;
        color: #17325c;
        margin: 0 0 0.25rem 0;
      }

      .item-subtitle {
        color: var(--accent);
        font-weight: 600;
        margin-bottom: 0.35rem;
      }

      .item-meta {
        color: var(--muted);
        font-size: 0.98rem;
        text-align: right;
        min-width: 200px;
      }

      .item-meta div + div {
        margin-top: 0.25rem;
      }

      .resume-list {
        margin: 1rem 0 0 0;
        padding-left: 1.2rem;
        color: var(--muted);
        line-height: 1.85;
        font-size: 1rem;
      }

      .resume-list li + li {
        margin-top: 0.35rem;
      }

      .skills-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
      }

      .skill-block {
        background: rgba(255, 255, 255, 0.88);
        border: 1px solid rgba(96, 165, 250, 0.14);
        border-radius: 20px;
        padding: 1.25rem;
      }

      .skill-block h3 {
        margin: 0 0 0.75rem 0;
        font-size: 1.05rem;
        color: #17325c;
      }

      .skill-block p {
        margin: 0;
        color: var(--muted);
        line-height: 1.8;
      }

      footer {
        margin-top: 4rem;
        padding: 1.5rem 0 2.5rem;
        color: var(--muted);
        text-align: center;
        border-top: 1px solid rgba(96, 165, 250, 0.12);
      }

      @media (max-width: 900px) {
        .skills-grid {
          grid-template-columns: 1fr;
        }

        .item-meta {
          text-align: left;
          min-width: auto;
        }
      }

      @media (max-width: 640px) {
        .nav-inner {
          justify-content: center;
        }

        .brand {
          width: 100%;
          text-align: center;
        }

        .nav-links {
          justify-content: center;
        }

        .top-contact {
          flex-direction: column;
          align-items: flex-start;
          gap: 0.75rem;
        }
      }
    </style>
  </head>

