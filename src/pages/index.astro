---
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Riya Hariyaplar</title>
    <meta name="robots" content="noindex, nofollow" />

    <style>
      :root {
        --bg: #f8fbff;
        --bg-soft: #eef5ff;
        --card: rgba(255, 255, 255, 0.92);
        --card-border: rgba(96, 165, 250, 0.18);
        --text: #122033;
        --muted: #4f6480;
        --accent: #2f6fed;
        --accent-2: #5c8df6;
        --line: rgba(96, 165, 250, 0.2);
        --shadow: 0 14px 40px rgba(37, 99, 235, 0.08);
        --leaf: #7aa36a;
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background:
          radial-gradient(circle at top left, rgba(147, 197, 253, 0.3), transparent 30%),
          radial-gradient(circle at top right, rgba(191, 219, 254, 0.45), transparent 28%),
          linear-gradient(180deg, #ffffff 0%, #f8fbff 45%, #eef5ff 100%);
        color: var(--text);
        position: relative;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      .container {
        width: min(1120px, calc(100% - 2rem));
        margin: 0 auto;
      }

      nav {
        position: sticky;
        top: 0;
        z-index: 20;
        backdrop-filter: blur(14px);
        background: rgba(255, 255, 255, 0.8);
        border-bottom: 1px solid rgba(96, 165, 250, 0.12);
      }

      .nav-inner {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1.1rem 0;
        gap: 1rem;
        flex-wrap: wrap;
      }

      .brand {
        font-size: 1.8rem;
        font-weight: 700;
        letter-spacing: -0.03em;
        color: #17325c;
      }

      .nav-links {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
      }

      .nav-links a {
        color: var(--muted);
        padding: 0.7rem 1rem;
        border-radius: 999px;
        transition: 0.2s ease;
        font-weight: 600;
      }

      .nav-links a:hover {
        background: rgba(96, 165, 250, 0.12);
        color: var(--accent);
      }

      .nav-links a.active {
        background: rgba(96, 165, 250, 0.14);
        color: var(--accent);
      }

      main {
        padding: 3.5rem 0 4rem;
        position: relative;
      }

      .hero {
        text-align: center;
        padding: 2rem 0 2.5rem;
        position: relative;
      }

      .avatar {
        width: 230px;
        height: 230px;
        border-radius: 50%;
        margin: 0 auto 1.75rem;
        object-fit: cover;
        display: block;
        border: 6px solid rgba(255, 255, 255, 0.95);
        box-shadow:
          0 0 0 2px rgba(96, 165, 250, 0.32),
          0 20px 48px rgba(37, 99, 235, 0.16);
      }

      .hero h1 {
        font-size: clamp(3rem, 7vw, 5rem);
        line-height: 1.02;
        margin: 0;
        letter-spacing: -0.05em;
        color: #10213a;
      }

      .subtitle {
        margin: 1rem auto 0;
        font-size: clamp(1.15rem, 2vw, 1.6rem);
        color: var(--accent);
        max-width: 850px;
        font-weight: 600;
      }

      .intro {
        max-width: 860px;
        margin: 1.5rem auto 0;
        font-size: 1.1rem;
        line-height: 1.95;
        color: var(--muted);
      }

      .button-row {
        display: flex;
        justify-content: center;
        gap: 1rem;
        flex-wrap: wrap;
        margin-top: 2.1rem;
      }

      .btn {
        display: inline-flex;
        align-items: center;
        gap: 0.65rem;
        border-radius: 999px;
        padding: 1rem 1.4rem;
        font-weight: 700;
        transition: 0.2s ease;
      }

      .btn-primary {
        background: linear-gradient(135deg, #2f6fed, #60a5fa);
        color: white;
        box-shadow: 0 10px 28px rgba(59, 130, 246, 0.18);
      }

      .btn-primary:hover {
        transform: translateY(-1px);
      }

      .btn-secondary {
        border: 1px solid rgba(47, 111, 237, 0.2);
        color: var(--accent);
        background: rgba(255, 255, 255, 0.72);
      }

      .btn-secondary:hover {
        background: rgba(219, 234, 254, 0.6);
      }

      section {
        margin-top: 4rem;
        position: relative;
      }

      .section-title {
        font-size: 2rem;
        margin-bottom: 0.75rem;
        color: #17325c;
      }

      .section-line {
        height: 1px;
        width: 100%;
        background: var(--line);
        margin-bottom: 1.5rem;
      }

      .education-card,
      .contact-card {
        background: var(--card);
        border: 1px solid var(--card-border);
        border-radius: 24px;
        box-shadow: var(--shadow);
      }

      .education-card {
        padding: 1.8rem;
      }

      .edu-top {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        align-items: start;
        flex-wrap: wrap;
      }

      .edu-school {
        font-size: 1.9rem;
        font-weight: 700;
        margin-bottom: 0.25rem;
        color: #17325c;
      }

      .edu-degree {
        font-size: 1.2rem;
        color: var(--accent);
        font-weight: 600;
      }

      .edu-right {
        text-align: right;
        min-width: 220px;
        color: var(--muted);
      }

      .edu-right strong {
        color: #17325c;
      }

      .edu-list {
        margin-top: 1.4rem;
        padding-left: 1.25rem;
        color: var(--muted);
        line-height: 1.85;
        font-size: 1.06rem;
      }

      .edu-list strong {
        color: #17325c;
      }

      .contact-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1rem;
      }

      .contact-card {
        padding: 1.4rem;
      }

      .contact-label {
        color: var(--accent);
        font-size: 0.98rem;
        margin-bottom: 0.55rem;
        font-weight: 700;
      }

      .contact-value {
        font-size: 1.08rem;
        line-height: 1.6;
        word-break: break-word;
        color: var(--text);
      }

      .contact-value a {
        text-decoration: underline;
        color: var(--accent);
      }

      .hidden-leaf {
        position: absolute;
        color: var(--leaf);
        opacity: 0.42;
        z-index: 1;
        pointer-events: none;
      }

      .leaf-one {
        top: 170px;
        right: 80px;
        transform: rotate(18deg);
      }

      .leaf-two {
        top: 920px;
        left: 24px;
        transform: rotate(-14deg);
      }

      .leaf-three {
        top: 1460px;
        right: 34px;
        transform: rotate(10deg);
      }

      footer {
        margin-top: 4rem;
        padding: 1.5rem 0 2.5rem;
        color: var(--muted);
        text-align: center;
        border-top: 1px solid rgba(96, 165, 250, 0.12);
      }

      @media (max-width: 900px) {
        .contact-grid {
          grid-template-columns: 1fr;
        }

        .edu-right {
          text-align: left;
        }

        .avatar {
          width: 190px;
          height: 190px;
        }

        .leaf-one {
          right: 28px;
        }

        .leaf-two {
          left: 10px;
        }

        .leaf-three {
          right: 12px;
        }
      }

      @media (max-width: 640px) {
        .nav-inner {
          justify-content: center;
        }

        .brand {
          width: 100%;
          text-align: center;
        }

        .nav-links {
          justify-content: center;
        }

        .hero h1 {
          font-size: 2.8rem;
        }

        .subtitle {
          font-size: 1.15rem;
        }

        .intro {
          font-size: 1rem;
          line-height: 1.8;
        }

        .hidden-leaf {
          display: none;
        }
      }
    </style>
  </head>

  <body>
    <nav>
      <div class="container nav-inner">
        <div class="brand">Riya Hariyaplar</div>
        <div class="nav-links">
          <a href="/" class="active">About</a>
          <a href="/resume">Resume</a>
          <a href="/skills">Skills &amp; Achievements</a>
          <a href="/interests">Interests</a>
        </div>
      </div>
    </nav>

    <main class="container">
