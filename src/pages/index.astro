          <path d="M17.63 3.84C14.54 2.94 10.98 3.3 8.2 5.09 4.73 7.31 3 11.19 3 15.48V21h5.52c4.29 0 8.17-1.73 10.39-5.2 1.79-2.78 2.15-6.34 1.25-9.43-.13-.47-.63-.74-1.1-.61-1.89.54-3.59 1.55-4.99 2.96-1.42 1.41-2.43 3.1-2.97 4.99a.79.79 0 0 1-1.52 0c-.54-1.89-1.55-3.58-2.96-4.99-.35-.35-.72-.68-1.11-.99.74-1.18 1.75-2.2 2.97-2.98 2.39-1.53 5.47-1.84 8.13-.95.42.14.87-.08 1.01-.5.15-.42-.08-.87-.49-1.01Z"/>
